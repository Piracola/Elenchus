# ==================================================================
# Elenchus — 环境变量配置
# 请将此文件复制并重命名为 .env，然后填入您的实际配置。
# ==================================================================

# ── LLM 认证密钥与路由端点 (LiteLLM 规范) ───────────────────
# 本项目使用 LiteLLM 作为底层路由 SDK。它会自动读取标准的系统环境变量。
# 您只需设置您需要使用的模型提供商。不需要的可以保持注释。

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
# OPENAI_API_BASE=https://api.openai.local/v1

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# DeepSeek
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_API_BASE=https://api.deepseek.com

# Groq
# GROQ_API_KEY=gsk-your-groq-key

# Ollama / 本地模型
# OLLAMA_API_BASE=http://localhost:11434

# 提示: 如果使用自定义中转，变量名遵循 [供应商]_API_BASE 格式。
# 常用: OPENAI_API_BASE, ANTHROPIC_API_BASE, AZURE_API_BASE 等。

# ── 搜索引擎配置 ────────────────────────────────────────────────────────
SEARXNG_BASE_URL=http://localhost:8080
TAVILY_API_KEY=tvly-your-tavily-api-key

# ── 数据库配置 ──────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./elenchus.db

# ── 服务器配置 ────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true
