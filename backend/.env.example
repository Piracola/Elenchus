# ==================================================================
# Elenchus — 环境变量配置
# 请将此文件复制并重命名为 .env，然后填入您的实际配置。
#
# 注意：LLM 提供商的 API 密钥通过前端 UI 的"模型配置"面板管理，
# 存储在数据库中（使用 Fernet 加密）。
# ==================================================================

# ── 安全配置 ──────────────────────────────────────────────────────
# Fernet 加密密钥，用于加密存储在数据库中的 API Key
# 生成方法: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ELENCHUS_ENCRYPTION_KEY=your-fernet-key-here

# ── 认证配置 ──────────────────────────────────────────────────────
# 启用用户认证（生产环境建议设为 true）
AUTH_ENABLED=false
# JWT 密钥（生产环境必须更改为强随机字符串）
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-in-production
# JWT 算法
JWT_ALGORITHM=HS256
# JWT 过期时间（分钟），默认 7 天
JWT_EXPIRE_MINUTES=10080

# ── 搜索引擎配置 ────────────────────────────────────────────────────
SEARXNG_BASE_URL=http://localhost:8080
TAVILY_API_KEY=tvly-your-tavily-api-key

# ── 数据库配置 ──────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./elenchus.db

# ── 服务器配置 ──────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
DEBUG=false
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174
