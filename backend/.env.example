# ==================================================================
# Elenchus — 环境变量配置
# 请将此文件复制并重命名为 .env，然后填入您的实际配置。
#
# 注意：LLM 提供商的 API 密钥通过前端 UI 的"模型配置"面板管理，
# 存储在 backend/data/providers.json（加密）中，无需在此配置。
# ==================================================================

# ── 搜索引擎配置 ────────────────────────────────────────────────────
SEARXNG_BASE_URL=http://localhost:8080
TAVILY_API_KEY=tvly-your-tavily-api-key

# ── 数据库配置 ──────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./elenchus.db

# ── 服务器配置 ──────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Provider 密钥加密主密钥 ─────────────────────────────────────────
# 用于加密 providers.json 中存储的 API key，必须设置。
# 生成命令: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PROVIDERS_ENCRYPTION_KEY=your-generated-fernet-key-here
