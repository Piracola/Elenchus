# Copy this file to `.env` and adjust values for your environment.

# Provider API keys are managed in the UI and stored encrypted in the database.
# You can leave this blank. Elenchus will generate and persist a local key
# automatically on first backend startup.
ELENCHUS_ENCRYPTION_KEY=

# Search providers
SEARXNG_BASE_URL=http://localhost:8080
TAVILY_API_KEY=

# Database
DATABASE_URL=sqlite+aiosqlite:///./elenchus.db

# Server
HOST=0.0.0.0
PORT=8001
DEBUG=false
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174
